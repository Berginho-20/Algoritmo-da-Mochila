#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <string.h>

typedef struct {
    int peso;
    int valor;
} Item;

typedef struct {
    int *genes;
    int fitness;
    int peso_total;
} Individuo;

Item *pesos_e_valores;
int n_itens_problema;
int peso_maximo_problema;

void calcular_metricas(Individuo *ind) {
    int p_total = 0;
    int v_total = 0;
    for (int i = 0; i < n_itens_problema; i++) {
        if (ind->genes[i] == 1) {
            if (pesos_e_valores[i].peso > peso_maximo_problema) {
                ind->fitness = 0;
                ind->peso_total = pesos_e_valores[i].peso;
                return;
            }
            p_total += pesos_e_valores[i].peso;
            v_total += pesos_e_valores[i].valor;
        }
    }
    ind->peso_total = p_total;
    ind->fitness = (p_total > peso_maximo_problema) ? 0 : v_total;
}

void criar_individuo(Individuo *ind) {
    ind->genes = malloc(sizeof(int) * n_itens_problema);
    int metodo = rand() % 3;
    if (metodo == 0) {
        for (int i = 0; i < n_itens_problema; i++) ind->genes[i] = rand() % 2;
    } else if (metodo == 1) {
        for (int i = n_itens_problema - 1; i >= 0; i--) ind->genes[i] = rand() % 2;
    } else {
        int meio = n_itens_problema / 2;
        for (int i = 0; i < meio; i++) ind->genes[i] = rand() % 2;
        for (int i = meio; i < n_itens_problema; i++) ind->genes[i] = rand() % 2;
    }
    calcular_metricas(ind);
}

void remover_duplicatas(Individuo populacao[], int n_cromossomos) {
    for (int i = 0; i < n_cromossomos; i++) {
        if (populacao[i].fitness <= 0) continue;
        for (int j = i + 1; j < n_cromossomos; j++) {
            if (memcmp(populacao[i].genes, populacao[j].genes, sizeof(int) * n_itens_problema) == 0) {
                populacao[j].fitness = 0;
            }
        }
    }
}

int comparar_individuos(const void *a, const void *b) {
    return ((Individuo*)b)->fitness - ((Individuo*)a)->fitness;
}

int sortear(Individuo pais[], int n_pais, int fitness_total, int indice_a_ignorar) {
    if (fitness_total <= 0) return rand() % n_pais;
    int temp_total = fitness_total;
    if (indice_a_ignorar != -1) temp_total -= pais[indice_a_ignorar].fitness;
    if (temp_total <= 0) return rand() % n_pais;
    float valor_sorteado = (float)rand() / (float)RAND_MAX;
    float acumulado = 0;
    for (int i = 0; i < n_pais; i++) {
        if (i == indice_a_ignorar) continue;
        acumulado += (float)pais[i].fitness / temp_total;
        if (acumulado >= valor_sorteado) return i;
    }
    return n_pais - 1;
}

void evoluir(Individuo populacao[], int n_cromossomos, float taxa_mutacao) {
    Individuo *pool = malloc(sizeof(Individuo) * n_cromossomos * 2);
    int fitness_total_pais = 0;
    for (int i = 0; i < n_cromossomos; i++) {
        pool[i] = populacao[i];
        if (populacao[i].fitness > 0) fitness_total_pais += populacao[i].fitness;
    }
    for (int i = 0; i < n_cromossomos; i++) {
        int idx_pai = sortear(populacao, n_cromossomos, fitness_total_pais, -1);
        int idx_mae = sortear(populacao, n_cromossomos, fitness_total_pais, idx_pai);
        Individuo filho;
        filho.genes = malloc(sizeof(int) * n_itens_problema);
        int corte = rand() % n_itens_problema;
        for (int j = 0; j < n_itens_problema; j++) {
            filho.genes[j] = (j < corte) ? populacao[idx_pai].genes[j] : populacao[idx_mae].genes[j];
        }
        if (((float)rand() / (float)RAND_MAX) < taxa_mutacao) filho.genes[rand() % n_itens_problema] ^= 1;
        calcular_metricas(&filho);
        pool[n_cromossomos + i] = filho;
    }
    remover_duplicatas(pool, n_cromossomos * 2);
    qsort(pool, n_cromossomos * 2, sizeof(Individuo), comparar_individuos);
    for (int i = 0; i < n_cromossomos; i++) {
        if (populacao[i].genes != pool[i].genes) free(populacao[i].genes);
        populacao[i] = pool[i];
    }
    for (int i = n_cromossomos; i < n_cromossomos * 2; i++) {
        int manter = 0;
        for(int k=0; k<n_cromossomos; k++) if(pool[i].genes == populacao[k].genes) manter = 1;
        if(!manter) free(pool[i].genes);
    }
    free(pool);
}

int main() {
    srand(time(NULL));
    char filename[100];
    int n_cromossomos, geracoes;
    float taxa_mutacao;

    if (scanf("%s %d %d %f", filename, &n_cromossomos, &geracoes, &taxa_mutacao) != 4) return 1;

    FILE *file = fopen(filename, "r");
    if (!file) return 1;

    if (fscanf(file, "%d %d", &n_itens_problema, &peso_maximo_problema) != 2) return 1;
    pesos_e_valores = malloc(sizeof(Item) * n_itens_problema);
    for (int i = 0; i < n_itens_problema; i++) {
        fscanf(file, "%d %d", &pesos_e_valores[i].valor, &pesos_e_valores[i].peso);
    }
    fclose(file);

    Individuo *populacao = malloc(sizeof(Individuo) * n_cromossomos);
    for (int i = 0; i < n_cromossomos; i++) criar_individuo(&populacao[i]);

    for (int g = 1; g <= geracoes; g++) {
        evoluir(populacao, n_cromossomos, taxa_mutacao);
        if (g == geracoes) {
            double soma = 0;
            for(int i = 0; i < n_cromossomos; i++) if(populacao[i].fitness > 0) soma += populacao[i].fitness;
            printf("Geracao: %d | Media: %.2f | Melhor: %d\n", g, soma/n_cromossomos, populacao[0].fitness);
        }
    }

    printf("\n--- RESULTADOS FINAIS ---\n");
    int limite = (n_cromossomos < 5) ? n_cromossomos : 5;
    for (int i = 0; i < limite; i++) {
        printf("VALOR: %d | PESO: %dg\n", populacao[i].fitness, populacao[i].peso_total);
    }

    for (int i = 0; i < n_cromossomos; i++) free(populacao[i].genes);
    free(populacao);
    free(pesos_e_valores);
    return 0;
}
